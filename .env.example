# ============================================================================
# Agri Cop — Environment Variables (Demo / Vercel)
# ============================================================================
#
# Copy this file to `.env.local` for local overrides.
# On Vercel, set these in: Project → Settings → Environment Variables.
#
# ALL variables are OPTIONAL.  The app runs in full demo mode (zero backend)
# when none of these are defined.
#
# ─── API ────────────────────────────────────────────────────────────────────
#
# Set VITE_API_URL if you want to connect to a real backend.
# Leave it unset to stay in demo mode (default).
#
# VITE_API_URL=https://api.yourdomain.com
#
# ─── NEVER commit secrets to this file ──────────────────────────────────────
# Do not put real API keys, database credentials, or tokens here.
# The demo credentials in config.demo.js are fake placeholders — intentional.
# ============================================================================
